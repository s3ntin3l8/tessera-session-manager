# Copy to .env and adjust. All values have safe defaults (see src/plugins/env.ts).

# Runtime environment: development | production | test
NODE_ENV=development

# HTTP port the server listens on.
PORT=3000

# Log verbosity: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# SQLite database location (file: URL).
DATABASE_URL=file:./data/app.db

# Optional. Enables AES-256-GCM encryption-at-rest for flagged columns.
# Must be a base64url-encoded 32-byte key. Leave empty to disable encryption.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
DB_ENCRYPTION_KEY=

# Comma-separated CORS allowlist (e.g. https://app.example.com,https://admin.example.com).
# Empty disables cross-origin requests.
CORS_ORIGIN=

# Rate limiting: max requests per window, and the window length.
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# Directory holding one dtach socket per terminal session. In production this
# should be an absolute path under the host user's state dir, e.g.
# /home/<user>/.local/state/claude-remote-session/sockets — see the deploy/
# systemd unit. Sessions survive as long as this directory does, independent
# of this process's own lifecycle/redeploys.
SESSIONS_DIR=./data/sessions
