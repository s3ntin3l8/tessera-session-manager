# Copy to .env and adjust. All values have safe defaults (see src/plugins/env.ts).

# Runtime environment: development | production | test
NODE_ENV=development

# HTTP port the server listens on.
PORT=3000

# Log verbosity: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# SQLite database location (file: URL).
DATABASE_URL=file:./data/app.db

# Optional. Enables AES-256-GCM encryption-at-rest for flagged columns.
# Must be a base64url-encoded 32-byte key. Leave empty to disable encryption.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
DB_ENCRYPTION_KEY=

# Comma-separated CORS allowlist (e.g. https://app.example.com,https://admin.example.com).
# Empty disables cross-origin requests.
CORS_ORIGIN=

# Rate limiting: max requests per window, and the window length.
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# Directory holding one dtach socket per terminal session. In production this
# should be an absolute path under the host user's state dir, e.g.
# /home/<user>/.local/state/claude-remote-session/sockets — see the deploy/
# systemd unit. Sessions survive as long as this directory does, independent
# of this process's own lifecycle/redeploys.
SESSIONS_DIR=./data/sessions

# Comma-separated list of directories to scan (immediate subdirectories only)
# for candidate projects — see GET /api/projects/discover. Empty disables
# discovery (opt-in only).
PROJECTS_ROOTS=

# Global (non-per-project) launcher/dock config dir — see
# src/services/project-config.ts. A project's own .crs/ dir always takes
# precedence over this.
CRS_CONFIG_DIR=~/.config/crs

# Multi-host support — see docs/multi-host.md: primary | agent. Leave as
# primary for a normal single-process deployment. "agent" is a lightweight,
# DB-less process meant to run on a remote host, exposing only a
# token-gated internal API (src/routes/internal.ts) that a primary uses to
# spawn/attach/terminate sessions on it.
TESSERA_ROLE=primary

# Required when TESSERA_ROLE=agent (the process refuses to boot without one).
# Shared secret the internal API requires on every request. Unused when
# TESSERA_ROLE=primary — per-remote-host tokens instead live in that
# primary's own `hosts` DB table (Settings -> Hosts).
TESSERA_AGENT_TOKEN=
