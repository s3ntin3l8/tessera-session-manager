\
# systemd --user unit — runs the app NATIVELY on the host (not containerized),
# per the pivotal architecture decision in
# .claude/plans/ok-i-m-thinking-of-merry-corbato.md: dtach masters must
# survive every redeploy, which a container lifecycle can't guarantee.
#
# NOT INSTALLED BY ANYTHING IN THIS REPO DIRECTLY — deploy/install.sh writes
# a copy of this file with the CHANGEME placeholders below substituted for
# real paths, then installs it. To do so by hand instead:
#   mkdir -p ~/.config/systemd/user
#   cp deploy/mullion.service ~/.config/systemd/user/
#   # edit the placeholders below first — see deploy/README.md
#   systemctl --user daemon-reload
#   systemctl --user enable --now mullion.service
#
# KillMode=control-group (systemd's default) only SIGTERMs processes in
# THIS unit's own cgroup on stop/restart — dtach masters are deliberately
# bootstrapped into their own separate transient scope
# (systemd-run --user --scope, see src/services/pty-manager.ts) precisely so
# they're NOT in this cgroup and survive every `systemctl --user restart`.
# Verified empirically in Milestone 1. scripts/self-update.sh's own detached
# updater relies on the exact same isolation to survive the restart it
# triggers in its own last step — and, separately, calls
# `systemctl --user restart <unit>` against whatever unit
# src/routes/updates.ts resolved from /proc/self/cgroup at apply time (see
# src/services/systemd-unit.ts), not a hardcoded name — so renaming this
# file no longer requires touching self-update.sh at all.
#
# WorkingDirectory below MUST be the versioned-release layout's `current`
# symlink (see deploy/install.sh), not the checkout/install root itself:
# DATABASE_URL and SESSIONS_DIR in .env are absolute paths outside any
# release (so an update never orphans the DB or live dtach sockets — see
# deploy/README.md), but drizzle/ and FRONTEND_DIST are resolved relative to
# this cwd deliberately, so they always come from whichever release
# `current` currently points at.

[Unit]
Description=Mullion — tiled terminal dashboard
After=network.target

[Service]
Type=simple

# CHANGE ME: absolute path to the install root's `current` symlink — e.g.
# /home/alice/opt/mullion/current. systemd does NOT expand env vars or "~"
# in unit files, so this must be a literal path, not "$MULLION_HOME/current".
WorkingDirectory=/home/CHANGEME/opt/mullion/current

# CHANGE ME: this repo pins Node via .nvmrc; systemd --user does not source
# nvm.sh, so this must be an absolute path to the exact nvm-managed node
# binary (find it with `nvm which` while that version is active, or
# `ls ~/.nvm/versions/node/`). "dist/server.js" is intentionally relative —
# it resolves against WorkingDirectory above, i.e. whichever release
# `current` points at.
ExecStart=/home/CHANGEME/.nvm/versions/node/vCHANGEME/bin/node dist/server.js

# Belt-and-suspenders, not required: %n expands to this unit's own literal
# name, so MULLION_SERVICE_UNIT is populated for free without editing .env —
# src/services/systemd-unit.ts's cgroup autodetection already resolves the
# same name at apply time, so this mostly matters for a host whose cgroup
# layout defeats that detection. Placed before EnvironmentFile below so an
# explicit MULLION_SERVICE_UNIT in .env (if you ever need one) still wins.
Environment=MULLION_SERVICE_UNIT=%n

# CHANGE ME: absolute path to this install's .env — OUTSIDE `current`/any
# release dir (e.g. /home/alice/opt/mullion/.env), since `current` is
# re-pointed wholesale on every update. Real secrets/config belong in a real
# .env file, not committed — see .env.example.
EnvironmentFile=/home/CHANGEME/opt/mullion/.env

Restart=on-failure
RestartSec=2

[Install]
WantedBy=default.target
